{
  "city": {
    "name": "Bangalore",
    "data_source": {
      "routes_csv": "https://raw.githubusercontent.com/thecont1/blr-traffic-monitor/main/csv-routes.csv",
      "traffic_csv": "https://raw.githubusercontent.com/thecont1/blr-traffic-monitor/main/csv-bangalore_traffic.csv"
    }
  },
  "percentile": {
    "worst_case": 90,
    "verdict_threshold_kmh": 0.5
  },
  "baseline": {
    "default_start": "2026-01-05",
    "default_end": "2026-03-02"
  },
  "defaults": {
    "period": "1m",
    "time_of_day": "weekday_morning",
    "question_mode": "worsened"
  },
  "route_pane": {
    "open": true,
    "width": 300,
    "min_width": 200,
    "max_width": 500
  }
}
