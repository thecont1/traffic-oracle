{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "private": true,
  "workspaces": [
    "lib/db",
    "lib/api-client-react",
    "lib/api-zod",
    "artifacts/api-server",
    "artifacts/blr-traffic",
    "artifacts/mockup-sandbox",
    "scripts"
  ],
  "scripts": {
    "dev": "echo 'Run specific package dev scripts (e.g. bun --filter @workspace/api-server run dev)'\n",
    "build": "bun run typecheck && bun exec --if-present run build",
    "typecheck": "bun run typecheck:libs && tsc -p artifacts/api-server/tsconfig.json --noEmit && tsc -p artifacts/blr-traffic/tsconfig.json --noEmit && tsc -p scripts/tsconfig.json --noEmit",
    "typecheck:libs": "tsc --build"
  },
  "overrides": {
    "@replit/vite-plugin-cartographer": "^0.5.1",
    "@replit/vite-plugin-dev-banner": "^0.1.1",
    "@replit/vite-plugin-runtime-error-modal": "^0.0.6",
    "@tailwindcss/vite": "^4.1.14",
    "@tanstack/react-query": "^5.90.21",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "framer-motion": "^12.23.24",
    "lucide-react": "^0.545.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "vite": "^7.3.2",
    "wouter": "^3.3.5",
    "zod": "^3.25.76",
    "esbuild": "0.27.3"
  }
}